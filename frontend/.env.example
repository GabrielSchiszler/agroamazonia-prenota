# Copie para .env ou use: ./start.sh prd|hml|dev
# O start.sh gera .env automaticamente a partir de backend/.env.{ambiente}

ENV_NAME=dev
API_URL=https://api-dev.agroamazonia.com/fast
API_KEY=dev

OAUTH2_FRONTEND_TOKEN_URL=https://api-auth-dev.agroamazonia.com/oauth2/token
OAUTH2_FRONTEND_CLIENT_ID=seu-client-id
OAUTH2_FRONTEND_CLIENT_SECRET=seu-client-secret
OAUTH2_FRONTEND_SCOPE=app-client-public/dev

# URLs por ambiente (referência):
#   prd: https://api-prd.agroamazonia.com/fast
#   hml: https://api-hml.agroamazonia.com/fast
#   dev: https://api-dev.agroamazonia.com/fast
